# Optional learner-state domain-extension slots.
# These do not feed the current ME-JEPA-Code Python ship gate. Omit E15-E21
# from production `mejepa_models_config.toml` until the real prodhost
# learner-state artifacts exist and pass digest verification.

[embedders.e15]
embedder = "e15"
name = "affect_speech"
kind = "learner_state"
path = "/var/cache/contextgraph/models/learner-state/affect-speech"
repo = "audeering/wav2vec2-large-robust-12-ft-emotion-msp-dim"
dimension = 1024
weight_files = ["model.safetensors", "preprocessor_config.json"]
manifest_sha256 = "REPLACE_WITH_REAL_SHA256"

[embedders.e16]
embedder = "e16"
name = "affect_face"
kind = "learner_state"
path = "/var/cache/contextgraph/models/learner-state/affect-face"
repo = "github:CMU-MultiComp-Lab/OpenFace-3.0 + hf:nutPace/openface_weights"
dimension = 512
weight_files = ["OpenFace/interface.py", "OpenFace/model/MLT.py", "OpenFace/weights/Alignment_RetinaFace.pth", "OpenFace/weights/Landmark_98.pkl", "OpenFace/weights/MTL_backbone.pth"]
manifest_sha256 = "REPLACE_WITH_REAL_SHA256"

[embedders.e17]
embedder = "e17"
name = "affect_text"
