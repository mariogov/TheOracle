# Phase 1b ME-JEPA embedder registry schema.
# This file is a template and is intentionally rejected by the production loader
# until every REPLACE_WITH_REAL_SHA256 is replaced by a real digest produced from
# the actual prodhost files. Production code refuses placeholders, missing files, path
# traversal, and digest mismatches.

schema_version = 1

[embedders.e1]
embedder = "e1"
name = "semantic"
kind = "content_pretrained"
path = "/var/cache/contextgraph/models/e1-e5-large-v2"
repo = "intfloat/e5-large-v2"
dimension = 1024
weight_files = ["config.json", "model.safetensors", "tokenizer.json"]
manifest_sha256 = "REPLACE_WITH_REAL_SHA256"

[embedders.e2]
embedder = "e2"
name = "temporal_recent"
kind = "content_deterministic"
path = ""
repo = ""
dimension = 512
weight_files = []
manifest_sha256 = ""

[embedders.e3]
embedder = "e3"
name = "temporal_periodic"
kind = "content_deterministic"
path = ""
repo = ""
dimension = 512
weight_files = []
manifest_sha256 = ""

[embedders.e4]
embedder = "e4"
name = "temporal_positional"
kind = "content_deterministic"
path = ""
repo = ""
dimension = 512
weight_files = []
manifest_sha256 = ""

[embedders.e5]
embedder = "e5"
