{
  "model": {
    "encoder": {
      "kind": "mlp",
      "hidden": [
        128
      ],
      "out_dim": 16
    },
    "predictor": {
      "kind": "mlp",
      "hidden": [
        128
      ],
      "in_action_dim": 233,
      "out_dim": 367
    },
    "target_architecture": "frozen_instrument_projection",
    "ema_momentum": 0.0
  },
  "loss": {
    "latent_mse_weight": 1.0,
    "vicreg_variance_weight": 3.0,
    "vicreg_covariance_weight": 0.2,
    "vicreg_target_std": 1.0
  },
  "optim": {
    "kind": "adamw",
    "lr": 0.01,
    "weight_decay": 0.0001,
    "warmup_steps": 0
  },
  "schedule": {
    "epochs": 800,
    "batch_size": 41,
    "device": "cuda"
  },
  "stopping": {
    "metric": "val_latent_mse",
    "target": 0.45,
    "max_seconds": 120
  },
  "seed": 42
}
